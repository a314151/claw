# Default provider. Must be one of:
# openai | deepseek | zhipu | qwen | gemini
LLM_PROVIDER=openai

# Provider API keys (set at least one)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
QWEN_API_KEY=
GEMINI_API_KEY=

# Provider model / endpoint overrides (optional)
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

DEEPSEEK_MODEL=deepseek-v3
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

ZHIPU_MODEL=glm-4.7
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

QWEN_MODEL=qwen3-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

GEMINI_MODEL=gemini-3-pro
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# 内置预设模型（可在网页中直接选择，也可手动输入其他模型）
# openai: gpt-5 / gpt-5-mini / gpt-4.1 / gpt-4o
# deepseek: deepseek-v3 / deepseek-r1 / deepseek-chat / deepseek-reasoner
# zhipu: glm-4.7 / glm-4-plus / glm-4-air / glm-4-flash
# qwen: qwen3-max / qwen3-plus / qwen-max / qwen-plus
# gemini: gemini-3-pro / gemini-3-flash / gemini-2.5-pro / gemini-2.5-flash

# Global generation controls
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_S=60

# Optional path for MCP server configuration JSON
MCP_CONFIG=./mcp_servers.json

# Assistant loop safety
ASSISTANT_MAX_TURNS=8

# Cloudflare R2 (对象存储，作为历史和画像持久化后端)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# 邮箱验证码登录（SMTP）
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_DEV_ECHO_CODE=false
